{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development pnpm exec nodemon --watch src --ext ts --exec \"pnpm run build && pnpm run start\"",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "db:check": "node ./build.mjs && node --enable-source-maps --env-file=.env ./dist/check-schema-drift.mjs",
    "db:migrate": "node ./build.mjs && node --enable-source-maps ./dist/migrate.mjs",
    "db:seed": "node ./build.mjs && node --enable-source-maps ./dist/db-init.mjs",
    "db:reset": "node ./build.mjs && node --enable-source-maps ./dist/db-reset.mjs",
    "db:normalize-questions": "node ./build.mjs && node --enable-source-maps --env-file=.env ./dist/normalize-questions.mjs",
    "db:check-normalization": "node ./build.mjs && node --enable-source-maps --env-file=.env ./dist/check-normalization.mjs",
    "db:populate-global-topics": "node ./build.mjs && node --enable-source-maps --env-file=.env ./dist/populate-global-topics.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.4.1",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "firebase-admin": "^12.0.0",
    "multer": "^2.1.1",
    "pino": "^9",
    "pino-http": "^10",
    "postgres": "^3.4.4",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.30.1",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "nodemon": "^3.0.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
