rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function adminByProfile() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{uid} {
      allow read: if owner(uid) || adminByProfile();
      allow create: if owner(uid) &&
        request.resource.data.keys().hasOnly(["email", "name", "role", "createdAt", "updatedAt"]) &&
        request.resource.data.role == "student";
      allow update: if adminByProfile() || (
        owner(uid) &&
        request.resource.data.keys().hasOnly(["email", "name", "role", "createdAt", "updatedAt"]) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["name", "updatedAt"])
      );
      allow delete: if false;
    }

    match /admin_categories/{docId} {
      allow read: if true;
      allow write: if adminByProfile();
    }

    match /admin_subcategories/{docId} {
      allow read: if true;
      allow write: if adminByProfile();
    }

    match /admin_tests/{docId} {
      allow read: if true;
      allow write: if adminByProfile();
    }

    match /admin_questions/{docId} {
      allow read: if true;
      allow write: if adminByProfile();
    }

    // Legacy single-document admin sync (kept for compatibility).
    match /admin_data/{docId} {
      allow read, write: if adminByProfile();
    }

    allow read, write: if false;
  }
}
